{
    "extends": "../../tsconfig.json",
    "compilerOptions": {
        /* Generación de tipos para que otros paquetes los usen */
        "composite": true,
        "declaration": true,
        "declarationMap": true,
        "emitDeclarationOnly": false,
        "outDir": "./dist"
    },
    "include": [
        "src/**/*"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}
{
  "name": "@nexia/ui-web",
  "version": "1.0.0",
  "description": "Web UI components for NEXIA",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./styles": "./dist/styles.css"
  },
"scripts": {
  "build:css": "tailwindcss -i ./src/styles/globals.css -o ./dist/styles.css --minify",
  "build": "tsc && npm run build:css",
  "dev": "tailwindcss -i ./src/styles/globals.css -o ./dist/styles.css --watch"
},
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "@tailwindcss/forms": "^0.5.10",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17"
  },
  "packageManager": "pnpm@10.15.0"
}
{
    "compilerOptions": {
        "target": "ESNext",
        "module": "ESNext",
        "lib": [
            "DOM",
            "ESNext"
        ],
        "moduleResolution": "bundler",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "baseUrl": ".",
        "paths": {
            "@/*": [
                "apps/web/src/*"
            ],
            "@shared": [
                "packages/shared/src"
            ],
            "@shared/*": [
                "packages/shared/src/*"
            ],
            "@nexia/ui-shared": [
                "packages/ui-shared/src"
            ],
            "@nexia/ui-shared/*": [
                "packages/ui-shared/src/*"
            ],
            "@ui/*": [
                "packages/ui-web/src/*"
            ]
        }
    },
    "include": [
        "apps",
        "packages"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}
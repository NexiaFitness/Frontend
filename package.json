{
  "name": "frontend",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.15.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "pnpm -F web dev",
    "build": "pnpm -r build",
    "build:web": "pnpm -F web build",
    "clean": "rm -rf node_modules pnpm-lock.yaml **/node_modules **/dist",
    "clean:cache": "rm -rf node_modules/.vite apps/web/node_modules/.vite",
    "test": "pnpm --filter web test",
    "test:watch": "pnpm --filter web vitest"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "pnpm": {
    "overrides": {
      "react": "18.3.1",
      "react-dom": "18.3.1"
    }
  }
}
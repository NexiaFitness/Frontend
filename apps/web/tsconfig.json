{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": ".",
    "types": ["vitest/globals", "@testing-library/jest-dom"],
    "paths": {
      "@/*": ["./src/*"],
      "@nexia/shared": ["../../packages/shared/dist/src/index"],
      "@nexia/shared/*": ["../../packages/shared/dist/src/*"]
